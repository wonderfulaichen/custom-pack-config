      "filePath": "data/example/config/text_settings.json",
      "key": "welcome_message"
    },
    "toggle_feature": {
      "type": "boolean",
      "default": "true",
      "category": "text_settings",
      "name": {
        "zh_cn": "启用功能",
        "en_us": "Enable Feature"
      },
      "description": {
        "zh_cn": "是否启用某个功能",
        "en_us": "Whether to enable a feature"
      },
      "tooltip": {
        "zh_cn": "切换功能的启用状态",
        "en_us": "Toggle feature on/off"
      },
      "filePath": "data/example/config/text_settings.json",
      "key": "toggle_feature"
    },
    "debug_mode": {
      "type": "boolean",
      "default": "true",
      "category": "advanced_settings",
      "categoryDisplayNames": {
        "zh_cn": {
          "advanced_settings": "高级设置"
        },
        "en_us": {
          "advanced_settings": "Advanced Settings"
        }
