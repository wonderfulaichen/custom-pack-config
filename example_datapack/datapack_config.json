      "tooltip": {
        "zh_cn": "点击按钮循环切换选项",
        "en_us": "Click button to cycle through options"
      },
      "enumDisplayNames": {
        "zh_cn": {
          "low": "低",
          "medium": "中",
          "high": "高",
          "ultra": "超高"
        },
        "en_us": {
          "low": "Low",
          "medium": "Medium",
          "high": "High",
          "ultra": "Ultra"
        }
      },
      "filePath": "data/example/config/choice_settings.json",
      "key": "cycle_selection"
    },
    "quality_enum": {
      "type": "enum",
      "default": "normal",
      "category": "choice_settings",
