        "zh_cn": "使用下拉菜单选择天气变化频率",
        "en_us": "Use dropdown menu to select weather change frequency"
      },
      "tooltip": {
        "zh_cn": "从下拉菜单中选择天气模式",
        "en_us": "Select weather mode from dropdown menu"
      },
      "enumDisplayNames": {
        "zh_cn": {
          "disabled": "禁用天气变化",
          "normal": "正常",
          "frequent": "频繁变化",
          "stormy": "暴风雨模式"
        },
        "en_us": {
          "disabled": "Disabled",
          "normal": "Normal",
          "frequent": "Frequent",
          "stormy": "Stormy"
        }
      },
      "filePath": "data/example/config/choice_settings.json",
      "key": "enum_example"
    },
    "color_rgb": {
      "type": "color",
