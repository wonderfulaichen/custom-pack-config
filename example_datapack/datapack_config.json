{
  "metadata": {
    "name": {
      "zh_cn": "示例数据包",
      "en_us": "Example Datapack"
    },
    "description": {
      "zh_cn": "展示数据包配置模组所有功能的完整示例",
      "en_us": "Complete example demonstrating all features of the datapack config mod"
    },
    "version": "1.0.0",
    "author": "Example Author",
    "requires_mod": "datapack_config_mod",
    "mod_version_min": "1.0.0"
  },
  "config": {
    "basic_enabled": {
      "type": "boolean",
      "default": "true",
      "category": "basic_settings",
      "categoryDisplayNames": {
        "zh_cn": {
          "basic_settings": "基础设置"
        },
        "en_us": {
          "basic_settings": "Basic Settings"
        }
      },
      "name": {
        "zh_cn": "启用数据包",
        "en_us": "Enable Datapack"
      },
      "description": {
        "zh_cn": "是否启用此数据包的功能",
        "en_us": "Whether to enable this datapack's features"
      },
      "tooltip": {
        "zh_cn": "控制数据包是否生效，关闭后数据包功能将完全禁用",
        "en_us": "Controls whether the datapack is active, all features will be disabled when turned off"
      },
      "filePath": "data/example/config/basic_settings.json",
      "key": "basic.enabled"
    },
    "difficulty_level": {
      "type": "enum_selector",
      "default": "normal",
      "category": "basic_settings",
      "enumValues": ["easy", "normal", "hard", "expert"],
      "name": {
        "zh_cn": "难度等级",
        "en_us": "Difficulty Level"
      },
      "description": {
        "zh_cn": "设置数据包的整体难度等级",
        "en_us": "Set the overall difficulty level of the datapack"
      },
      "tooltip": {
        "zh_cn": "点击按钮循环切换难度等级",
        "en_us": "Click button to cycle through difficulty levels"
      },
      "enumDisplayNames": {
        "zh_cn": {
          "easy": "简单",
          "normal": "普通",
          "hard": "困难",
          "expert": "专家"
        },
        "en_us": {
          "easy": "Easy",
          "normal": "Normal",
          "hard": "Hard",
          "expert": "Expert"
        }
      },
      "filePath": "data/example/config/basic_settings.json",
      "key": "difficulty"
    },
    "slider_example": {
      "type": "slider",
      "default": "50",
      "min": 0,
      "max": 100,
      "step": 1,
      "category": "numeric_settings",
      "categoryDisplayNames": {
        "zh_cn": {
          "numeric_settings": "数值设置"
        },
        "en_us": {
          "numeric_settings": "Numeric Settings"
        }
      },
      "name": {
        "zh_cn": "滑块示例",
        "en_us": "Slider Example"
      },
      "description": {
        "zh_cn": "使用滑块调整整数值",
        "en_us": "Use slider to adjust integer value"
      },
      "tooltip": {
        "zh_cn": "拖动滑块在0-100之间调整数值，每次调整1",
        "en_us": "Drag slider to adjust value between 0-100, step of 1"
      },
      "filePath": "data/example/config/numeric_settings.json",
      "key": "slider_value"
    },
    "int_example": {
      "type": "int",
      "default": "25",
      "min": 1,
      "max": 100,
      "category": "numeric_settings",
      "name": {
        "zh_cn": "整数输入示例",
        "en_us": "Integer Input Example"
      },
      "description": {
        "zh_cn": "直接输入整数值",
        "en_us": "Directly input integer value"
      },
      "tooltip": {
        "zh_cn": "输入1-100之间的整数",
        "en_us": "Enter an integer between 1-100"
      },
      "filePath": "data/example/config/numeric_settings.json",
      "key": "int_value"
    },
    "double_slider_example": {
      "type": "double_slider",
      "default": "1.5",
      "min": 0.1,
      "max": 5.0,
      "step": 0.1,
      "category": "numeric_settings",
      "name": {
        "zh_cn": "浮点滑块示例",
        "en_us": "Double Slider Example"
      },
      "description": {
        "zh_cn": "使用滑块调整浮点数值",
        "en_us": "Use slider to adjust double value"
      },
      "tooltip": {
        "zh_cn": "拖动滑块在0.1-5.0之间调整数值，每次调整0.1",
        "en_us": "Drag slider to adjust value between 0.1-5.0, step of 0.1"
      },
      "filePath": "data/example/config/numeric_settings.json",
      "key": "double_value"
    },
    "double_example": {
      "type": "double",
      "default": "2.0",
      "min": 0.1,
      "max": 5.0,
      "category": "numeric_settings",
      "name": {
        "zh_cn": "浮点输入示例",
        "en_us": "Double Input Example"
      },
      "description": {
        "zh_cn": "直接输入浮点数值",
        "en_us": "Directly input double value"
      },
      "tooltip": {
        "zh_cn": "输入0.1-5.0之间的浮点数",
        "en_us": "Enter a double value between 0.1-5.0"
      },
      "filePath": "data/example/config/numeric_settings.json",
      "key": "double_slider_value"
    },
    "spawn_rate_slider": {
      "type": "slider",
      "default": "50",
      "min": 0,
      "max": 100,
      "step": 1,
      "category": "mob_spawning",
      "categoryDisplayNames": {
        "zh_cn": {
          "mob_spawning": "生物生成"
        },
        "en_us": {
          "mob_spawning": "Mob Spawning"
        }
      },
      "name": {
        "zh_cn": "生物生成率",
        "en_us": "Mob Spawn Rate"
      },
      "description": {
        "zh_cn": "调整自定义生物的生成概率",
        "en_us": "Adjust spawn probability of custom mobs"
      },
      "tooltip": {
        "zh_cn": "拖动滑块调整数值，0为不生成，100为最高概率",
        "en_us": "Drag slider to adjust value, 0 means no spawn, 100 means highest probability"
      },
      "filePath": "data/example/config/spawning.json",
      "key": "slider_value"
    },
    "max_mobs_int": {
      "type": "int",
      "default": "25",
      "min": 1,
      "max": 200,
      "category": "mob_spawning",
      "name": {
        "zh_cn": "最大生物数量",
        "en_us": "Max Mob Count"
      },
      "description": {
        "zh_cn": "直接输入每区域最大生物数量",
        "en_us": "Directly input max mob count per region"
      },
      "tooltip": {
        "zh_cn": "输入1-200之间的整数",
        "en_us": "Enter an integer between 1-200"
      },
      "filePath": "data/example/config/spawning.json",
      "key": "int_value"
    },
    "damage_multiplier": {
      "type": "double_slider",
      "default": "1.0",
      "min": 0.1,
      "max": 5.0,
      "step": 0.1,
      "category": "combat_system",
      "categoryDisplayNames": {
        "zh_cn": {
          "combat_system": "战斗系统"
        },
        "en_us": {
          "combat_system": "Combat System"
        }
      },
      "name": {
        "zh_cn": "伤害倍率",
        "en_us": "Damage Multiplier"
      },
      "description": {
        "zh_cn": "使用滑块调整武器伤害倍率",
        "en_us": "Use slider to adjust weapon damage multiplier"
      },
      "tooltip": {
        "zh_cn": "拖动滑块调整伤害倍率，支持小数",
        "en_us": "Drag slider to adjust damage multiplier, supports decimals"
      },
      "filePath": "data/example/config/combat.json",
      "key": "damage_multiplier"
    },
    "defense_value": {
      "type": "double",
      "default": "1.5",
      "min": 0.5,
      "max": 3.0,
      "category": "combat_system",
      "name": {
        "zh_cn": "防御系数",
        "en_us": "Defense Coefficient"
      },
      "description": {
        "zh_cn": "直接输入防御系数数值",
        "en_us": "Directly input defense coefficient value"
      },
      "tooltip": {
        "zh_cn": "输入0.5-3.0之间的浮点数",
        "en_us": "Enter a float value between 0.5-3.0"
      },
      "filePath": "data/example/config/combat.json",
      "key": "defense_value"
    },
    "dropdown_example": {
      "type": "enum",
      "default": "option_b",
      "category": "choice_settings",
      "categoryDisplayNames": {
        "zh_cn": {
          "choice_settings": "选择设置"
        },
        "en_us": {
          "choice_settings": "Choice Settings"
        }
      },
      "enumValues": ["option_a", "option_b", "option_c"],
      "name": {
        "zh_cn": "下拉菜单示例",
