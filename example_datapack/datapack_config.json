      "name": {
        "zh_cn": "调试模式",
        "en_us": "Debug Mode"
      },
      "description": {
        "zh_cn": "启用调试信息输出（批量修改示例）",
        "en_us": "Enable debug information output (batch modification example)"
      },
      "tooltip": {
