          "text_settings": "文本设置"
        },
        "en_us": {
          "text_settings": "Text Settings"
        }
      },
      "name": {
        "zh_cn": "欢迎消息",
        "en_us": "Welcome Message"
      },
      "description": {
        "zh_cn": "输入自定义的欢迎消息文本",
        "en_us": "Enter custom welcome message text"
