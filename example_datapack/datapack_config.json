      },
      "description": {
        "zh_cn": "使用下拉菜单选择选项",
        "en_us": "Use dropdown menu to select option"
      },
      "tooltip": {
        "zh_cn": "从下拉菜单中选择一个选项",
        "en_us": "Select an option from dropdown menu"
      },
      "enumDisplayNames": {
        "zh_cn": {
          "option_a": "选项A",
          "option_b": "选项B",
          "option_c": "选项C"
        },
        "en_us": {
          "option_a": "Option A",
          "option_b": "Option B",
          "option_c": "Option C"
        }
      },
      "filePath": "data/example/config/choice_settings.json",
      "key": "dropdown_selection"
    },
    "enum_selector_example": {
      "type": "enum_selector",
      "default": "low",
